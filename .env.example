# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Same Google OAuth client as configured in Supabase → Authentication → Providers → Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: redirect URI registered in Google Cloud (often not required for refresh-token use)
GOOGLE_OAUTH_REDIRECT_URI=

# OpenAI (document classification, embeddings, chat)
OPENAI_API_KEY=
# Optional overrides:
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CLASSIFY_MODEL=gpt-4o-mini
# OPENAI_CHAT_MODEL=gpt-4o-mini
# Uploads: PDF/images are parsed with the Responses API (then embedded). Fallback: pdf-parse for PDF if this fails.
# OPENAI_DOCUMENT_PARSE_MODEL=gpt-4o-mini
# OPENAI_DOCUMENT_PARSE_FALLBACK_MODEL=gpt-4o
# OPENAI_DOCUMENT_PARSE_DISABLED=true
